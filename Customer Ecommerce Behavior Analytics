WITH Clean_Interactions AS (
    SELECT 
        t.transaction_id,
        i.exposure_timestamp,
        ROW_NUMBER() OVER(PARTITION BY t.transaction_id ORDER BY i.exposure_timestamp DESC) as rn
    FROM fact_transactions t
    JOIN fact_user_interactions i 
        ON t.user_id = i.user_id AND t.stimulus_id = i.stimulus_id
    WHERE i.exposure_timestamp <= t.checkout_timestamp
),
Valid_Interactions AS (
    SELECT transaction_id, exposure_timestamp 
    FROM Clean_Interactions 
    WHERE rn = 1
)
SELECT 
    t.transaction_id,
    u.age_group,
    CASE WHEN u.avg_monthly_income >= 10000000 THEN 'High Income' ELSE 'Low Income' END AS income_bracket,
    s.stimulus_category,
    vi.exposure_timestamp,
    t.checkout_timestamp,
    
    ROUND((EXTRACT(EPOCH FROM (t.checkout_timestamp - vi.exposure_timestamp)) / 60)::numeric, 2) AS conversion_time_mins,
    
    t.payment_method,
    CASE WHEN t.payment_method = 'PayLater' THEN 1 ELSE 0 END AS is_paylater_int,
    t.is_impulsive_flag,
    p.order_status,
    p.cancellation_reason,
    CASE WHEN p.order_status = 'Cancelled' THEN 1 ELSE 0 END AS is_cancelled_int,
    p.is_late_payment,
    CASE WHEN p.is_late_payment = TRUE THEN 1 ELSE 0 END AS is_late_payment_int
FROM fact_transactions t
JOIN Valid_Interactions vi ON t.transaction_id = vi.transaction_id
LEFT JOIN dim_users u ON t.user_id = u.user_id
LEFT JOIN dim_conversion_stimulus s ON t.stimulus_id = s.stimulus_id
LEFT JOIN fact_post_purchase_behavior p ON t.transaction_id = p.transaction_id
WHERE t.is_stimulus_driven = TRUE 
  AND EXTRACT(EPOCH FROM (t.checkout_timestamp - vi.exposure_timestamp)) / 60 <= 120;  



