WITH TrustMatrix AS (
    SELECT 
        cart_abandonment_factors,
        CASE 
            WHEN customer_reviews_importance IN (4, 5) AND review_reliability IN ('Heavily', 'Moderately') THEN '1. The Devotees (High Expectation & Trust)'
            WHEN customer_reviews_importance IN (4, 5) AND review_reliability IN ('Rarely', 'Never') THEN '2. The Disappointed (High Expectation, Broken Trust)'
            WHEN customer_reviews_importance IN (1, 2) AND review_reliability IN ('Heavily', 'Moderately') THEN '3. The Pragmatists (Low Expectation, High Trust)'
            WHEN customer_reviews_importance IN (1, 2) AND review_reliability IN ('Rarely', 'Never') THEN '4. The Cynics (Zero Expectation & Trust)'
        END AS trust_segment
    FROM amazon_behavior
    WHERE cart_abandonment_factors IS NOT NULL
      AND LOWER(cart_abandonment_factors) != 'others'
),
SegmentPopulation AS (
    SELECT 
        trust_segment,
        COUNT(*) AS total_segment_population
    FROM TrustMatrix
    WHERE trust_segment IS NOT NULL
    GROUP BY trust_segment
),
RankedFactors AS (
    SELECT 
        t.trust_segment,
        t.cart_abandonment_factors,
        COUNT(*) AS total_abandonment,
        ROW_NUMBER() OVER(PARTITION BY t.trust_segment ORDER BY COUNT(*) DESC) AS rn
    FROM TrustMatrix t
    WHERE t.trust_segment IS NOT NULL 
    GROUP BY t.trust_segment, t.cart_abandonment_factors
)
SELECT 
    r.trust_segment,
    r.total_abandonment,
    s.total_segment_population,
    r.cart_abandonment_factors AS top_abandonment_reason
FROM RankedFactors r
JOIN SegmentPopulation s ON r.trust_segment = s.trust_segment
WHERE r.rn <= 2 
ORDER BY r.trust_segment, r.rn;
