--Social Proof (1) REVIEW - PURCHASE CATEGORIES - Car Abandonment 
WITH TrustMatrix AS (
    SELECT 
        purchase_categories,
        cart_abandonment_factors,
        CASE 
            WHEN customer_reviews_importance IN (4, 5) AND review_reliability IN ('Heavily', 'Moderately') THEN ' The Devotees (High Expectation, High Trust)'
            WHEN customer_reviews_importance IN (4, 5) AND review_reliability IN ('Rarely', 'Never') THEN ' The Disappointed (High Expectation, Broken Trust)'
            WHEN customer_reviews_importance IN (1, 2) AND review_reliability IN ('Heavily', 'Moderately') THEN ' The Pragmatists (Low Expectation, High Trust)'
            WHEN customer_reviews_importance IN (1, 2) AND review_reliability IN ('Rarely', 'Never') THEN 'The Cynics (Zero Expectation, Zero Trust)'
        END AS trust_segment
    FROM amazon_behavior
    WHERE cart_abandonment_factors IS NOT NULL
),
RankedFactors AS (
    SELECT 
        purchase_categories,
        trust_segment,
        cart_abandonment_factors,
        COUNT(*) AS total_abandonment,
        SUM(COUNT(*)) OVER(PARTITION BY purchase_categories) AS total_category_population,
        ROW_NUMBER() OVER(PARTITION BY purchase_categories, trust_segment ORDER BY COUNT(*) DESC) AS rn
    FROM TrustMatrix
    WHERE trust_segment IS NOT NULL 
    GROUP BY purchase_categories, trust_segment, cart_abandonment_factors
)
SELECT 
    purchase_categories,
    total_category_population,
    trust_segment,
    total_abandonment,
    cart_abandonment_factors AS top_factors
FROM RankedFactors
WHERE rn IN (1, 2, 3)              -- Mengambil Juara 1 dan Juara 2
  AND total_abandonment >= 20   -- Eliminasi jumlah di bawah 20 (Threshold)
ORDER BY purchase_categories, trust_segment, rn;

