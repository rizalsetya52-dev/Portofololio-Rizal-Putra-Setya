---- AI Algoritma

WITH RecommendationMatrix AS (
    SELECT 
        cart_abandonment_factors,
        CASE 
            WHEN personalized_recommendation_score IN (4, 5) AND rating_accuracy_score IN (4, 5) THEN '1. High Freq, High Relevance'
            WHEN personalized_recommendation_score IN (4, 5) AND rating_accuracy_score IN (1, 2) THEN '2. High Freq, Low Relevance'
            WHEN personalized_recommendation_score IN (1, 2) AND rating_accuracy_score IN (4, 5) THEN '3. Low Freq, High Relevance'
            WHEN personalized_recommendation_score IN (1, 2) AND rating_accuracy_score IN (1, 2) THEN '4. Low Freq, Low Relevance'
        END AS rec_segment
    FROM amazon_behavior
    WHERE cart_abandonment_factors IS NOT NULL
      AND LOWER(cart_abandonment_factors) != 'others' -- Filter Out Noise
      AND personalized_recommendation_score IS NOT NULL 
      AND rating_accuracy_score IS NOT NULL
),
RankedFactors AS (
    SELECT 
        rec_segment,
        cart_abandonment_factors,
        COUNT(*) AS total_abandonment,
        ROW_NUMBER() OVER(PARTITION BY rec_segment ORDER BY COUNT(*) DESC) AS rn
    FROM RecommendationMatrix
    WHERE rec_segment IS NOT NULL 
    GROUP BY rec_segment, cart_abandonment_factors
)
SELECT 
    rec_segment,
    rn AS rank,
    total_abandonment,
    cart_abandonment_factors AS top_abandonment_reason
FROM RankedFactors
WHERE rn <= 2 -- Buang alasan ketiga agar Heatmap Power BI lebih rapi
ORDER BY rec_segment, rn;

WITH RecommendationMatrix AS (
    SELECT 
        cart_abandonment_factors,
        personalized_recommendation_frequency,
        CASE 
            -- Segmen 1: Skor Tinggi & Akurasi Tinggi (Untuk Yes & Sometimes)
            WHEN personalized_recommendation_frequency IN ('Yes', 'Sometimes') 
                 AND personalized_recommendation_score IN (4, 5) 
                 AND rating_accuracy_score IN (4, 5) THEN '1. High Relevance'
            
            -- Segmen 2: Skor Tinggi tapi Akurasi Rendah (Untuk Yes & Sometimes)
            WHEN personalized_recommendation_frequency IN ('Yes', 'Sometimes') 
                 AND personalized_recommendation_score IN (4, 5) 
                 AND rating_accuracy_score IN (1, 2) THEN '2. High Score, Low Accuracy'
            
            -- Segmen 3: Skor Rendah tapi Akurasi Tinggi (Untuk Yes & Sometimes)
            WHEN personalized_recommendation_frequency IN ('Yes', 'Sometimes') 
                 AND personalized_recommendation_score IN (1, 2) 
                 AND rating_accuracy_score IN (4, 5) THEN '3. Low Score, High Accuracy'
            
            -- Segmen 4: Skor Rendah & Akurasi Rendah (Untuk Yes & Sometimes)
            WHEN personalized_recommendation_frequency IN ('Yes', 'Sometimes') 
                 AND personalized_recommendation_score IN (1, 2) 
                 AND rating_accuracy_score IN (1, 2) THEN '4. Low Relevance'
        END AS rec_segment
    FROM amazon_behavior
    WHERE cart_abandonment_factors IS NOT NULL
      AND LOWER(cart_abandonment_factors) != 'others' 
      AND personalized_recommendation_score IS NOT NULL 
      AND rating_accuracy_score IS NOT NULL
      AND personalized_recommendation_frequency IN ('Yes', 'Sometimes')
),
RankedFactors AS (
    SELECT 
        rec_segment,
        personalized_recommendation_frequency,
        cart_abandonment_factors,
        COUNT(*) AS total_abandonment,
        ROW_NUMBER() OVER(
            PARTITION BY rec_segment, personalized_recommendation_frequency 
            ORDER BY COUNT(*) DESC
        ) AS rn
    FROM RecommendationMatrix
    WHERE rec_segment IS NOT NULL 
    GROUP BY rec_segment, personalized_recommendation_frequency, cart_abandonment_factors
)
SELECT 
    rec_segment,
    personalized_recommendation_frequency,
    rn AS rank,
    total_abandonment,
    cart_abandonment_factors AS top_abandonment_reason
FROM RankedFactors
WHERE rn <= 2 
ORDER BY rec_segment, personalized_recommendation_frequency, rn;









