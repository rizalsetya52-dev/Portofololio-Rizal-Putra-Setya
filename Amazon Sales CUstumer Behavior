---SaveForLater OR Cognitive Offloading
WITH MicroActionPersona AS (
    SELECT 
        cart_abandonment_factors,
        CASE 
            WHEN add_to_cart_browsing IN ('Yes', 'Maybe') AND saveforlater_frequency IN ('Always', 'Often', 'Sometimes') 
            THEN '1. High Cognitive Offloader (Cart as Memory)'
            
            WHEN add_to_cart_browsing IN ('Yes', 'Maybe') AND saveforlater_frequency IN ('Rarely', 'Never') 
            THEN '2. Transient Browser (High Impulsivity)'
            
            WHEN add_to_cart_browsing = 'No' AND saveforlater_frequency IN ('Always', 'Often', 'Sometimes') 
            THEN '3. Cautious Planner (Explicit Save)'
            
            WHEN add_to_cart_browsing = 'No' AND saveforlater_frequency IN ('Rarely', 'Never') 
            THEN '4. Intent-Driven Buyer (Cart for Checkout)'
        END AS offloading_behavior
    FROM amazon_behavior
    WHERE cart_abandonment_factors IS NOT NULL
      AND LOWER(cart_abandonment_factors) != 'others' -- Filter Out Noise
      AND add_to_cart_browsing IS NOT NULL
      AND saveforlater_frequency IS NOT NULL
),
SegmentPopulation AS (
    SELECT 
        offloading_behavior,
        COUNT(*) AS total_segment_population
    FROM MicroActionPersona
    GROUP BY offloading_behavior
),
RankedFactors AS (
    SELECT 
        mp.offloading_behavior,
        mp.cart_abandonment_factors,
        COUNT(*) AS total_abandonment,
        ROW_NUMBER() OVER(PARTITION BY mp.offloading_behavior ORDER BY COUNT(*) DESC) AS rn
    FROM MicroActionPersona mp
    WHERE mp.offloading_behavior IS NOT NULL
    GROUP BY mp.offloading_behavior, mp.cart_abandonment_factors
)
SELECT 
    r.offloading_behavior,
    r.total_abandonment,
    s.total_segment_population,
    r.cart_abandonment_factors AS top_abandonment_reason
FROM RankedFactors r
JOIN SegmentPopulation s ON r.offloading_behavior = s.offloading_behavior
WHERE r.rn <= 2 -- Hanya ambil 2 alasan utama
ORDER BY r.offloading_behavior, r.rn;


